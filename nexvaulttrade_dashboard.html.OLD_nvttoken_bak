<script>
    // ---------- EMAILJS CONFIG ----------
    const emailJSConfig = {
        publicKey: "B0F__pze3E_1rpORN",
        serviceID: "service_s88i1y1",
        templateID: "template_0ivff4w"
    };
    emailjs.init(emailJSConfig.publicKey);

    // ---------- AUTH GATE ----------
    if (!localStorage.getItem('nvt_token')) {
        window.location.href = 'nexvaulttrade_login.html';
    }

    // ---------- API / BACKEND ----------
    let useBackend = true;
    const API_BASE_URL = 'https://nexvaulttrade-backend.onrender.com/api';
    let authToken = localStorage.getItem('nvt_token');
    let adminToken = localStorage.getItem('nvt_adminToken');
    let currentUser = null;
    let withdrawalRequests = [];
    let processingTimers = {};
    let adminMessages = [];

    async function apiCall(endpoint, options = {}) {
        if (!useBackend) throw new Error('Backend not available');
        const headers = { 'Content-Type': 'application/json', ...options.headers };
        if (authToken && !endpoint.includes('/auth/admin-login')) headers['x-auth-token'] = authToken;
        if (adminToken && endpoint.includes('/admin')) headers['x-auth-token'] = adminToken;
        const res = await fetch(`${API_BASE_URL}${endpoint}`, { ...options, headers });
        if (!res.ok) {
            const err = await res.json();
            throw new Error(err.msg || 'API error');
        }
        return res.json();
    }
// ---------- LOCALSTORAGE FALLBACK ----------
    let localUsers = [];
    function loadLocalData() {
        const stored = localStorage.getItem('nexvault_users');
        if(stored) localUsers = JSON.parse(stored);
        else {
            localUsers = [{ id: 'user1', name: 'TOWOBOLA OYELADE', email: 'towobola@example.com', password: 'demo123', balance: 0, isVerified: false, requiresAdditionalVerification: false, memberSince: new Date().toISOString(), totalDeposit: 0, totalWithdrawal: 0, transactions: [] }];
            saveLocalUsers();
        }
        const storedMsgs = localStorage.getItem('nexvault_admin_messages');
        if(storedMsgs) adminMessages = JSON.parse(storedMsgs);
        const storedWithdrawals = localStorage.getItem('nexvault_withdrawal_requests');
        if(storedWithdrawals) withdrawalRequests = JSON.parse(storedWithdrawals);
    }
    function saveLocalUsers() { localStorage.setItem('nexvault_users', JSON.stringify(localUsers)); }
    function saveLocalMessages() { localStorage.setItem('nexvault_admin_messages', JSON.stringify(adminMessages)); }
    function saveLocalWithdrawals() { localStorage.setItem('nexvault_withdrawal_requests', JSON.stringify(withdrawalRequests)); }

    // ---------- AUTH FUNCTIONS ----------
    async function loginUser(email, password) {
        if (useBackend) {
            const data = await apiCall('/auth/login', { method: 'POST', body: JSON.stringify({ email, password }) });
            authToken = data.token;
            localStorage.setItem('nvt_token', authToken);
            currentUser = data.user;
        } else {
            const user = localUsers.find(u => u.email === email && u.password === password);
            if (!user) throw new Error('Invalid credentials');
            currentUser = user;
            authToken = 'local_' + user.id;
            localStorage.setItem('nvt_token', authToken);
        }
        await loadUserData();
        return true;
    }
    async function signupUser(name, email, password) {
        if (useBackend) {
            const data = await apiCall('/auth/signup', { method: 'POST', body: JSON.stringify({ name, email, password }) });
            authToken = data.token;
            localStorage.setItem('nvt_token', authToken);
            currentUser = data.user;
        } else {
            if (localUsers.find(u => u.email === email)) throw new Error('User already exists');
            const newUser = { id: 'user_' + Date.now(), name, email, password, balance: 0, isVerified: false, requiresAdditionalVerification: false, memberSince: new Date().toISOString(), totalDeposit: 0, totalWithdrawal: 0, transactions: [] };
            localUsers.push(newUser);
            saveLocalUsers();
            currentUser = newUser;
            authToken = 'local_' + newUser.id;
            localStorage.setItem('nvt_token', authToken);
        }
        await loadUserData();
        return true;
    }
    async function loadUserData() {
        if (useBackend && authToken && !authToken.startsWith('local_')) {
            const user = await apiCall('/user/me');
            currentUser = user;
            const requests = await apiCall('/user/withdrawal-requests');
            withdrawalRequests = requests;
        } else {
            const requests = withdrawalRequests.filter(r => r.userId === currentUser.id);
            withdrawalRequests = requests;
        }
        updateAllUI();
        if(document.getElementById('profileName')) {
            document.getElementById('profileName').innerText = currentUser.name;
            document.getElementById('profileEmail').innerText = currentUser.email;
            document.getElementById('profileSince').innerText = new Date(currentUser.memberSince).toLocaleDateString();
            document.getElementById('profileVerified').innerText = currentUser.isVerified ? 'Verified' : 'Unverified';
        }
    }
    async function deposit(amount, method) {
        if (useBackend && authToken && !authToken.startsWith('local_')) {
            await apiCall('/user/deposit', { method: 'POST', body: JSON.stringify({ amount, method }) });
            await loadUserData();
        } else {
            currentUser.balance += amount;
            currentUser.totalDeposit += amount;
            currentUser.transactions.unshift({ type: 'Deposit', amount, date: new Date().toISOString(), details: method });
            const index = localUsers.findIndex(u => u.id === currentUser.id);
            if (index !== -1) localUsers[index] = currentUser;
            saveLocalUsers();
            updateAllUI();
        }
    }
    async function requestWithdrawal(method, amount, address, memo, fee, netAmount) {
        if (useBackend && authToken && !authToken.startsWith('local_')) {
            const data = await apiCall('/user/request-withdrawal', { method: 'POST', body: JSON.stringify({ method, amount, address, memo, fee, netAmount }) });
            return data.request;
        } else {
            const request = { id: Date.now().toString(), userId: currentUser.id, method, amount, address, memo, fee, netAmount, status: 'pending', date: new Date().toISOString() };
            withdrawalRequests.push(request);
            saveLocalWithdrawals();
            return request;
        }
    }
       // ---------- UI UPDATE ----------
    function updateAllUI() {
        if (!currentUser) return;
        document.getElementById('currentUserName').innerText = currentUser.name;
        document.getElementById('currentBalance').innerText = `$${currentUser.balance.toFixed(2)}`;
        document.getElementById('totalDepositStat').innerText = `$${currentUser.totalDeposit.toFixed(2)}`;
        document.getElementById('totalWithdrawalStat').innerText = `$${currentUser.totalWithdrawal.toFixed(2)}`;
        document.getElementById('memberName').innerText = currentUser.name;
        document.getElementById('memberSince').innerText = new Date(currentUser.memberSince).toLocaleDateString();
        const badge = document.getElementById('accountBadge');
        if(currentUser.isVerified) {
            badge.textContent = 'Verified';
            badge.classList.add('verified');
        } else {
            badge.textContent = 'Unverified';
            badge.classList.remove('verified');
        }
        const refLink = `https://NexvaultTrade.com/${currentUser.name.replace(/ /g, '_')}`;
        document.getElementById('referralLinkDisplay').innerText = refLink;
        const recentDiv = document.getElementById('recentTransactions');
        const transactions = currentUser.transactions || [];
        if(transactions.length === 0) recentDiv.innerHTML = 'No transactions found';
        else recentDiv.innerHTML = transactions.slice(0,3).map(tx => `<div class="transaction-item"><div>${tx.type}</div><div>$${tx.amount.toFixed(2)}</div><div>${new Date(tx.date).toLocaleString()}</div></div>`).join('');
        document.getElementById('depositAvailableBalance').innerText = `$${currentUser.balance.toFixed(2)}`;
        document.getElementById('depositTotalDeposited').innerText = `$${currentUser.totalDeposit.toFixed(2)}`;
        document.getElementById('withdrawalAvailableBalance').innerText = `$${currentUser.balance.toFixed(2)}`;
        document.getElementById('withdrawalTotalWithdrawn').innerText = `$${currentUser.totalWithdrawal.toFixed(2)}`;
        const historyDiv = document.getElementById('transactionHistoryList');
        if(transactions.length === 0) historyDiv.innerHTML = '<p>No transactions yet.</p>';
        else historyDiv.innerHTML = transactions.map(tx => `<div class="transaction-item"><div>${tx.type}</div><div>$${tx.amount.toFixed(2)}</div><div>${new Date(tx.date).toLocaleString()}</div></div>`).join('');
        const warningDiv = document.getElementById('additionalVerificationWarning');
        if(warningDiv) warningDiv.style.display = currentUser.requiresAdditionalVerification ? 'flex' : 'none';
        const pendingCount = withdrawalRequests.filter(r => r.status === 'pending').length;
        document.getElementById('pendingWithdrawalsCount').innerText = pendingCount;
        renderUserWithdrawalHistory();
        checkAndStartProcessingTimer();
    }
    function renderUserWithdrawalHistory() {
        const container = document.getElementById('withdrawalRequestsList');
        if(!container) return;
        const userRequests = withdrawalRequests.filter(r => r.userId === currentUser.id);
        if(userRequests.length === 0) container.innerHTML = '<p>No withdrawal requests.</p>';
