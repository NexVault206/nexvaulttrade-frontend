    document.getElementById('requestWithdrawalBtn')?.addEventListener('click', async () => {
        if(!currentUser) return;

        // Block if already processing
        const processingEnd = localStorage.getItem(`processing_end_${currentUser.id}`);
        if(processingEnd && parseInt(processingEnd) > Date.now()) {
            showToast('A withdrawal is already processing. Please wait.');
            setWithdrawalStage('processing');
            return;
        }

        let amt = parseFloat(document.getElementById('withdrawAmount').value);
        let addr = document.getElementById('withdrawAddress').value.trim();
        let memo = document.getElementById('withdrawMemo')?.value.trim() || '';
        if(!window.selectedWithdrawMethod) { showToast('Select a withdrawal method first'); return; }
        const method = window.selectedWithdrawMethod;
        if(isNaN(amt) || amt < method.min) { showToast(`Minimum withdrawal is $${method.min}`); return; }
        if(amt > method.max) { showToast(`Maximum withdrawal is $${method.max}`); return; }
        if(amt > currentUser.balance) { showToast('Insufficient balance'); return; }
        if(!addr) { showToast('Enter destination address'); return; }

        const fee = (amt * method.feePercent) / 100;
        const netAmount = amt - fee;

        try {
            // Save the amount in case we need it for the blocked screen
            lastWithdrawalAmount = amt;
            localStorage.setItem(`wd_pending_amount_${currentUser.id}`, amt);

            await requestWithdrawal(method.name, amt, addr, memo, fee, netAmount);

            // Start 30-min timer — unverified check happens AFTER timer ends
            showToast('✓ Withdrawal submitted. 30-minute security hold started.');
            localStorage.setItem(`processing_end_${currentUser.id}`, Date.now() + 30 * 60 * 1000);
