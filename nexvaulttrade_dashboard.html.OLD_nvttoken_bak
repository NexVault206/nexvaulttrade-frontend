<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>NexvaultTrade | Full Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            padding: 20px 16px 90px 16px;
            transition: background 0.3s, color 0.2s;
        }
        :root {
            --bg-primary: #0A0E17;
            --bg-secondary: #0F1624;
            --bg-card: #0F1624;
            --bg-elevated: #131A2C;
            --border: #1E293B;
            --text-primary: #EFF3FC;
            --text-secondary: #94A3B8;
            --accent: #D4AF37;
            --accent-dark: #B8860B;
            --accent-hover: #C5A028;
            --success: #2BE07E;
            --warning: #FFB347;
            --danger: #FF4D4D;
        }
        body.light {
            --bg-primary: #F1F5F9;
            --bg-secondary: #FFFFFF;
            --bg-card: #FFFFFF;
            --bg-elevated: #E2E8F0;
            --border: #CBD5E1;
            --text-primary: #0F172A;
            --text-secondary: #475569;
            --accent: #B8860B;
            --accent-dark: #8B6508;
            --accent-hover: #9A7209;
            --success: #10B981;
            --warning: #F59E0B;
            --danger: #EF4444;
        }
        .app-container { max-width: 1280px; margin: 0 auto; }
        .screen { transition: opacity 0.2s; }
        .hidden { display: none; }

        .logo-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 12px;
        }
        .logo { display: flex; align-items: center; gap: 12px; cursor: pointer; }
        .logo-icon {
            background: linear-gradient(135deg, var(--accent), #F3E5AB);
            width: 40px; height: 40px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 22px;
            color: #0A0E17;
        }
        .logo-text {
            font-size: 26px;
            font-weight: 800;
            background: linear-gradient(120deg, var(--text-primary), var(--accent));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .header-actions { display: flex; align-items: center; gap: 12px; }
        .theme-toggle {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 40px;
            padding: 8px 14px;
            cursor: pointer;
            font-size: 18px;
            color: var(--text-primary);
        }
        .badge-status {
            background: rgba(212, 175, 55, 0.15);
            border: 1px solid rgba(212, 175, 55, 0.4);
            padding: 6px 14px;
            border-radius: 40px;
            font-size: 13px;
            font-weight: 500;
            color: var(--accent);
        }
        .badge-status.verified {
            background: rgba(34, 197, 94, 0.15);
            border-color: rgba(34, 197, 94, 0.4);
            color: var(--success);
        }
        .stats-grid, .deposit-stats, .withdrawal-stats, .plan-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 16px;
            margin-bottom: 32px;
        }
        .stat-pill, .stat-card {
            background: var(--bg-card);
            border-radius: 28px;
            padding: 18px 16px;
            border: 1px solid var(--border);
        }
        .stat-value { font-size: 28px; font-weight: 800; margin: 8px 0; }
        .method-section {
            background: var(--bg-card);
            border-radius: 32px;
            padding: 24px;
            margin-bottom: 28px;
            border: 1px solid var(--border);
        }
        .tabs { display: flex; gap: 12px; margin-bottom: 24px; border-bottom: 1px solid var(--border); padding-bottom: 12px; flex-wrap: wrap; }
        .tab-btn {
            background: transparent; border: none; color: var(--text-secondary);
            font-weight: 600; padding: 8px 18px; border-radius: 40px; cursor: pointer;
        }
        .tab-btn.active { background: var(--accent); color: #0A0E17; }
        .search-box {
            background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 60px;
            padding: 12px 18px; display: flex; gap: 10px; margin-bottom: 28px;
        }
        .search-box input { background: transparent; border: none; width: 100%; color: var(--text-primary); outline: none; }
        .methods-table { width: 100%; border-collapse: collapse; }
        .methods-table th, .methods-table td { padding: 14px 8px; text-align: left; border-bottom: 1px solid var(--border); }
        .btn-primary, .quick-deposit-btn, .complete-btn, .request-btn {
            background: var(--accent); border: none; padding: 12px 28px;
            border-radius: 44px; font-weight: 700; color: #0A0E17; cursor: pointer;
            transition: 0.2s;
        }
        .btn-primary:hover, .quick-deposit-btn:hover, .complete-btn:hover, .request-btn:hover {
            background: var(--accent-hover);
        }
        .btn-secondary {
            background: var(--bg-secondary); border: 1px solid var(--border);
            padding: 12px 28px; border-radius: 44px; color: var(--text-primary); cursor: pointer;
        }
        .btn-danger {
            background: var(--danger); border: none; padding: 8px 16px;
            border-radius: 40px; font-weight: 600; color: white; cursor: pointer;
        }
        .btn-outline {
            background: transparent; border: 1px solid var(--accent);
            padding: 8px 20px; border-radius: 40px; color: var(--accent); font-weight: 600; cursor: pointer;
        }
        .plan-card {
            background: var(--bg-secondary);
            border-radius: 28px; padding: 24px;
            margin-bottom: 20px; border: 1px solid var(--border);
        }
        .amount-slider { width: 100%; margin: 16px 0; }
        .input-field {
            background: var(--bg-secondary); border: 1px solid var(--border);
            border-radius: 60px; padding: 14px 18px; width: 100%;
            color: var(--text-primary); margin-bottom: 16px;
        }
        .bottom-nav {
            position: fixed; bottom: 0; left: 0; right: 0;
            background: var(--bg-primary);
            backdrop-filter: blur(20px);
            display: flex; justify-content: space-around; padding: 12px 20px;
            border-top: 1px solid var(--border);
            max-width: 600px; margin: 0 auto;
            width: 100%; border-radius: 32px 32px 0 0;
            left: 50%; transform: translateX(-50%); z-index: 100;
        }
        .nav-item {
            display: flex; flex-direction: column; align-items: center;
            gap: 4px; font-size: 12px; color: var(--text-secondary); cursor: pointer;
        }
        .nav-item i { font-size: 22px; }
        .nav-item.active { color: var(--accent); }
        .message-float {
            position: fixed; bottom: 90px; right: 20px;
            background: var(--accent); width: 56px; height: 56px;
            border-radius: 50%; display: flex; align-items: center;
            justify-content: center; cursor: pointer; z-index: 150;
            box-shadow: 0 6px 16px rgba(212,175,55,0.4);
        }
        .message-float i { color: #0A0E17; font-size: 24px; }
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.85); backdrop-filter: blur(8px);
            z-index: 1000; display: flex; align-items: center; justify-content: center;
            visibility: hidden; opacity: 0; transition: 0.2s;
        }
        .modal-overlay.active { visibility: visible; opacity: 1; }
        .message-modal, .upgrade-modal, .switch-modal, .login-modal, .email-modal {
            background: var(--bg-card);
            border-radius: 48px;
            max-width: 500px; width: 90%; padding: 28px;
        }
        .close-modal {
            background: var(--bg-secondary); width: 36px; height: 36px;
            border-radius: 40px; display: flex; align-items: center;
            justify-content: center; cursor: pointer;
        }
        .toast-msg {
            position: fixed; bottom: 85px; left: 50%; transform: translateX(-50%);
            background: var(--bg-secondary); color: var(--text-primary);
            padding: 8px 18px; border-radius: 40px;
            font-size: 13px; z-index: 200;
            border: 1px solid var(--border);
        }
        .action-buttons-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-top: 20px;
        }
        .action-item {
            background: var(--bg-secondary);
            border-radius: 28px;
            padding: 18px 22px;
            display: flex;
            align-items: center;
            gap: 16px;
            cursor: pointer;
            transition: 0.2s;
            border: 1px solid var(--border);
        }
        .action-item:hover { background: var(--bg-elevated); }
        .action-icon { font-size: 28px; color: var(--accent); }
        .action-text { font-weight: 600; font-size: 18px; }
        .transaction-item {
            background: var(--bg-secondary);
            border-radius: 20px;
            padding: 14px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .admin-user-row, .withdrawal-request-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            border-bottom: 1px solid var(--border);
            flex-wrap: wrap;
            gap: 10px;
        }
        .message-item {
            background: var(--bg-secondary);
            border-radius: 20px;
            padding: 12px;
            margin-bottom: 12px;
        }
        .wallet-edit { display: flex; gap: 8px; margin-top: 8px; }
        .warning-red {
            background: rgba(255, 77, 77, 0.15);
            border-left: 4px solid var(--danger);
            padding: 16px;
            border-radius: 16px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--danger);
        }
        .timer-display {
            background: var(--bg-secondary);
            border-radius: 40px;
            padding: 8px 16px;
            display: inline-block;
            margin-bottom: 16px;
            font-family: monospace;
            font-size: 20px;
        }
        @media (max-width: 760px) {
            .stats-grid, .deposit-stats, .withdrawal-stats { grid-template-columns: 1fr 1fr; }
            .message-float { bottom: 85px; right: 16px; width: 48px; height: 48px; }
        }
    </style>
</head>
<body>
<div class="app-container">
    <div class="logo-header">
        <div class="logo" id="adminLoginTrigger">
            <div class="logo-icon">N</div>
            <div class="logo-text">NexvaultTrade</div>
        </div>
        <div class="header-actions">
            <div class="theme-toggle" id="themeToggle"><i class="fas fa-moon"></i></div>
            <div id="accountBadge" class="badge-status">Unverified</div>
        </div>
    </div>
    <!-- Site Navigation -->
    <div style="display:flex; gap:16px; padding:10px 16px; background:var(--bg-secondary); border-bottom:1px solid var(--border); flex-wrap:wrap; font-size:0.85rem;">
        <a href="nexvaulttrade_index.html" style="color:var(--accent); text-decoration:none; font-weight:600;">🏠 Home</a>
        <a href="nexvaulttrade_aboutus.html" style="color:var(--text-secondary); text-decoration:none;">About Us</a>
        <a href="nexvaulttrade_services.html" style="color:var(--text-secondary); text-decoration:none;">Services</a>
        <a href="nexvaulttrade_contact.html" style="color:var(--text-secondary); text-decoration:none;">Contact</a>
        <span style="margin-left:auto; color:var(--text-secondary); cursor:pointer;" onclick="localStorage.removeItem('nvt_token'); localStorage.removeItem('nvt_user'); window.location.href='nexvaulttrade_login.html';">Logout 🚪</span>
    </div>
<!-- Auth handled by login/signup pages -->

    <!-- MAIN APP SCREEN (visible after login) -->
    <div id="appScreen" style="display:block;">
        <!-- DASHBOARD SCREEN -->
        <div id="dashboardScreen" class="screen">
            <div class="welcome-card" style="background:var(--bg-elevated); border-radius:28px; padding:18px 22px; margin-bottom:24px; display:flex; justify-content:space-between; flex-wrap:wrap;">
                <div><h2>Welcome back, <span id="currentUserName"></span>!</h2><p id="currentDate"></p></div>
                <button id="dashboardQuickDeposit" class="quick-deposit-btn"><i class="fas fa-bolt"></i> + Quick Deposit</button>
            </div>
            <div class="balance-card" style="background:linear-gradient(145deg,var(--bg-secondary),var(--bg-primary)); border-radius:32px; padding:24px; margin-bottom:24px;">
                <div class="balance-label">Account Balance</div>
                <div class="balance-amount" style="font-size:56px; font-weight:800;" id="currentBalance">$0.00</div>
                <div style="color:var(--success); font-size:13px;"><i class="fas fa-circle"></i> Available for Withdrawal</div>
                <div style="font-size:12px; color:var(--text-secondary); margin:8px 0 20px;">Last updated: <span id="lastUpdated"></span></div>
                <div class="action-buttons" style="display:flex; gap:18px;">
                    <button id="dashboardDepositBtn" class="btn-primary"><i class="fas fa-arrow-down"></i> Deposit</button>
                    <button id="dashboardWithdrawBtn" class="btn-secondary"><i class="fas fa-arrow-up"></i> Withdraw</button>
                </div>
            </div>
            <div class="stats-grid">
                <div class="stat-pill"><div class="stat-label">Total Profit</div><div class="stat-value">$0.00</div><div>+2.5% Last period</div></div>
                <div class="stat-pill"><div class="stat-label">Bonus</div><div class="stat-value">$0.00</div><div>Rewards</div></div>
                <div class="stat-pill"><div class="stat-label">Referral Bonus</div><div class="stat-value">$0.00</div><div>From invites</div></div>
                <div class="stat-pill"><div class="stat-label">Total Deposit</div><div class="stat-value" id="totalDepositStat">$0.00</div><div>All time</div></div>
                <div class="stat-pill"><div class="stat-label">Total Withdrawal</div><div class="stat-value" id="totalWithdrawalStat">$0.00</div><div>All time</div></div>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:32px;">
                <div class="refer-card" style="background:var(--bg-card); border-radius:28px; padding:22px;"><h4>Refer & Earn</h4><p>Earn commission when someone signs up using your link</p><div style="background:var(--bg-secondary); padding:10px; border-radius:18px; display:flex; justify-content:space-between; flex-wrap:wrap;"><span id="referralLinkDisplay"></span><button id="copyRefLink" style="background:var(--bg-elevated); border:none; padding:6px 12px; border-radius:30px; color:var(--text-primary);">Copy</button></div><div style="display:flex; justify-content:space-between; margin-top:16px;"><div><strong>0</strong><br>Total Referrals</div><div><strong>$0.00</strong><br>Earnings</div></div></div>
                <div class="platform-card" style="background:var(--bg-card); border-radius:28px; padding:22px;"><h4>Platform Stats</h4><div style="display:flex; justify-content:space-between; padding:8px 0;"><span>Activity</span><span style="color:var(--success);">Active</span></div><div style="display:flex; justify-content:space-between; padding:8px 0;"><span>Total Users</span><span id="totalUsersStat">-</span></div><div style="display:flex; justify-content:space-between; padding:8px 0;"><span>Total Investments</span><span>$9.5M+</span></div></div>
            </div>
            <div class="plans-section" style="background:var(--bg-card); border-radius:32px; padding:24px;">
                <div style="display:flex; justify-content:space-between;"><h4>No Active Plans</h4><button id="buyPlanBtn" class="btn-primary">+ Buy a Plan</button></div>
                <p>You don't have any active investment plans at the moment. Start growing your wealth today!</p>
                <div style="display:flex; justify-content:space-between; margin:16px 0;"><span><i class="fas fa-history"></i> Recent Transactions</span><span style="color:var(--accent);">View all</span></div>
                <div id="recentTransactions" style="background:var(--bg-secondary); text-align:center; padding:30px; border-radius:24px;">No transactions found</div>
                <div style="display:flex; justify-content:space-between; background:var(--bg-elevated); padding:12px; border-radius:24px; margin-top:16px;"><span><i class="far fa-user-circle"></i> <span id="memberName"></span></span><span>Member since <span id="memberSince"></span></span></div>
                <div style="display:flex; gap:20px; margin-top:16px;"><button id="smallDepositBtn" class="btn-primary">Deposit</button><button id="smallWithdrawBtn" class="btn-secondary">Withdraw</button></div>
            </div>
        </div>
     <!-- DEPOSIT SCREEN -->
        <div id="depositScreen" class="screen hidden">
            <div class="deposit-stats">
                <div class="stat-pill"><div class="stat-label">AVAILABLE BALANCE</div><div class="stat-number" id="depositAvailableBalance">$0.00</div></div>
                <div class="stat-pill"><div class="stat-label">TOTAL DEPOSITED</div><div class="stat-number" id="depositTotalDeposited">$0.00</div></div>
                <div class="stat-pill"><div class="stat-label">PENDING DEPOSITS</div><div class="stat-number">$0.00</div></div>
                <div class="stat-pill"><div class="stat-label">LAST DEPOSIT</div><div class="stat-number">$0.00</div></div>
            </div>
            <div class="method-section">
                <h3>Select Deposit Method</h3>
                <div class="tabs"><button class="tab-btn active" data-tab="all">All Methods</button><button class="tab-btn" data-tab="crypto">Crypto</button><button class="tab-btn" data-tab="bank">Bank Transfer</button></div>
                <div class="search-box"><i class="fas fa-search"></i><input type="text" id="searchDeposit" placeholder="Search payment methods..."></div>
                <table class="methods-table"><thead><tr><th>METHOD</th><th>LIMITS</th><th>ACTION</th></tr></thead><tbody id="depositMethodsBody"></tbody>}</div>
            <div id="depositFlowArea" style="display:none;">
                <div class="deposit-details-card" style="background:var(--bg-secondary); border-radius:28px; padding:24px; margin-top:20px;"><h3>Deposit via <span id="selectedMethodName"></span></h3><label>Amount to deposit</label><div><span>$</span><input type="number" id="depositAmountInput" class="amount-input" value="100" style="background:transparent; border:none; font-size:24px; width:100%; color:var(--text-primary);"></div><button id="confirmDepositBtn" class="complete-btn">Complete Deposit</button><p class="terms-text">By proceeding, you agree to our terms</p></div>
                <div id="depositInstructions" style="display:none;" class="payment-instructions"><div id="walletInfo"></div><div class="security-tips"><h4>Security Tips</h4><ul><li>Always verify payment details</li><li>Use secure connection</li></ul></div></div>
            </div>
        </div>
                    <!-- WITHDRAWAL SCREEN -->
        <div id="withdrawalScreen" class="screen hidden">
            <!-- STATS -->
            <div class="withdrawal-stats">
                <div class="stat-pill"><div class="stat-label">AVAILABLE BALANCE</div><div class="stat-number" id="withdrawalAvailableBalance">$0.00</div></div>
                <div class="stat-pill"><div class="stat-label">TOTAL WITHDRAWN</div><div class="stat-number" id="withdrawalTotalWithdrawn">$0.00</div></div>
                <div class="stat-pill"><div class="stat-label">PENDING</div><div class="stat-number" id="pendingWithdrawalsCount">0</div></div>
                <div class="stat-pill"><div class="stat-label">LAST WITHDRAWAL</div><div class="stat-number" id="lastWithdrawalStat">—</div></div>
            </div>

            <!-- STAGE 1: FORM (default — shown when no active processing) -->
            <div id="wdStageForm">
                <div class="method-section">
                    <h3>Select Withdrawal Method</h3>
                    <div class="tabs" id="withdrawalTabs">
                        <button class="tab-btn active" data-wtab="all">All Methods</button>
                        <button class="tab-btn" data-wtab="crypto">Crypto</button>
                        <button class="tab-btn" data-wtab="bank">Bank Transfer</button>
                    </div>
                    <div class="search-box"><i class="fas fa-search"></i><input type="text" id="searchWithdrawal" placeholder="Search payment methods..."></div>
                    <table class="methods-table"><thead><tr><th>METHOD</th><th>LIMITS</th><th>FEE</th><th>ACTION</th></tr></thead><tbody id="withdrawalMethodsBody"></tbody></table>
                </div>
                <div id="withdrawalFormArea" style="display:none;">
                    <div class="withdrawal-details-card" style="background:var(--bg-secondary);border-radius:28px;padding:24px;">
                        <h3>Withdraw via <span id="selectedWithdrawMethodName"></span></h3>
                        <div class="input-group"><label>Amount (USD)</label><input type="number" id="withdrawAmount" class="input-field" placeholder="Amount"></div>
                        <div class="input-group"><label>Destination Address</label><input type="text" id="withdrawAddress" class="input-field" placeholder="Destination address"></div>
                        <div id="memoGroup" style="display:none;"><label>Memo/Tag</label><input type="text" id="withdrawMemo" class="input-field" placeholder="Memo/Tag"></div>
                        <div id="feeDisplay" style="margin:10px 0;font-size:14px;color:var(--text-secondary);"></div>
                        <button id="requestWithdrawalBtn" class="request-btn">Request Withdrawal</button>
                        <p style="font-size:12px;margin-top:12px;color:var(--text-secondary);">Withdrawals go through a 30-minute security hold after submission.</p>
                    </div>
                </div>
            </div>

            <!-- STAGE 2: PROCESSING TIMER (shown after user submits) -->
            <div id="wdStageProcessing" style="display:none;">
                <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:28px;padding:32px 24px;text-align:center;margin-bottom:16px;">
                    <div style="width:80px;height:80px;border-radius:50%;background:rgba(255,179,71,0.15);border:2px solid rgba(255,179,71,0.4);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;font-size:36px;">⏳</div>
                    <h3 style="font-size:18px;font-weight:800;margin-bottom:8px;">Processing Withdrawal</h3>
                    <p style="font-size:13px;color:var(--text-secondary);margin-bottom:20px;">Your withdrawal request is under a 30-minute security hold. Please wait.</p>
                    <div style="background:var(--bg-elevated);border-radius:20px;padding:20px;margin-bottom:16px;">
                        <div style="font-size:11px;font-weight:700;color:var(--text-secondary);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">Time Remaining</div>
                        <div id="timerCountdown" style="font-size:48px;font-weight:800;color:var(--warning);letter-spacing:2px;font-variant-numeric:tabular-nums;">30:00</div>
                    </div>
                    <div style="display:flex;align-items:center;justify-content:center;gap:8px;font-size:13px;color:var(--text-secondary);">
                        <i class="fas fa-shield-alt" style="color:var(--warning);"></i>
                        Security verification in progress...
                    </div>
                </div>
            </div>

            <!-- STAGE 3: UNVERIFIED BLOCK (shown after timer ends if account not verified) -->
            <div id="wdStageUnverified" style="display:none;">
