    window.addEventListener('click', (e) => {
        if(e.target.classList.contains('modal-overlay')) e.target.classList.remove('active');
    });
    document.getElementById('messageFloatBtn').addEventListener('click', () => document.getElementById('adminMessageModal').classList.add('active'));

    // Initialization
    (async () => {
        useBackend = true;
        loadLocalData();
        if (authToken) {
            try {
                await loadUserData();
                // App is already visible (display:block)
            } catch(e) {
                localStorage.removeItem('nvt_token');
                localStorage.removeItem('nvt_user');
                window.location.href = 'nexvaulttrade_login.html';
                return;
            }
        } else {
            window.location.href = 'nexvaulttrade_login.html';
            return;
        }
        renderDepositMethods();
        renderWithdrawalMethods();
        setInterval(() => { if(currentUser) checkAndStartProcessingTimer(); }, 1000);
    })();
</script>
</body>
