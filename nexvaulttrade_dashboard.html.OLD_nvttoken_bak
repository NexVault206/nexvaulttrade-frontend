    // ── WITHDRAWAL STAGE MANAGER ──
    // Stages: 'form' | 'processing' | 'unverified' | 'success'
    let lastWithdrawalAmount = 0;

    function setWithdrawalStage(stage) {
        document.getElementById('wdStageForm').style.display        = stage === 'form'        ? 'block' : 'none';
        document.getElementById('wdStageProcessing').style.display  = stage === 'processing'  ? 'block' : 'none';
        document.getElementById('wdStageUnverified').style.display  = stage === 'unverified'  ? 'block' : 'none';
        document.getElementById('wdStageSuccess').style.display     = stage === 'success'     ? 'block' : 'none';
    }

    function resetWithdrawalStage() {
        if (currentUser) localStorage.removeItem(`processing_end_${currentUser.id}`);
        if (currentUser && processingTimers[currentUser.id]) {
            clearInterval(processingTimers[currentUser.id]);
            delete processingTimers[currentUser.id];
        }
        setWithdrawalStage('form');
    }

    function openMessageAdmin() {
        document.getElementById('adminMessageModal').classList.add('active');
    }

    function startProcessingTimer(userId) {
        if(processingTimers[userId]) clearInterval(processingTimers[userId]);
        const existing = localStorage.getItem(`processing_end_${userId}`);
        const endTime = existing ? parseInt(existing) : Date.now() + 30 * 60 * 1000;
        if (!existing) localStorage.setItem(`processing_end_${userId}`, endTime);

        setWithdrawalStage('processing');

        const tick = () => {
            const remaining = Math.max(0, endTime - Date.now());
            const minutes = Math.floor(remaining / 60000);
            const seconds = Math.floor((remaining % 60000) / 1000);
            const timerSpan = document.getElementById('timerCountdown');
            if(timerSpan) timerSpan.innerText = `${String(minutes).padStart(2,'0')}:${String(seconds).padStart(2,'0')}`;
            if(remaining <= 0) {
                clearInterval(processingTimers[userId]);
                delete processingTimers[userId];
                localStorage.removeItem(`processing_end_${userId}`);
                finalizeWithdrawalProcessing(userId);
            }
        };
        tick();
        processingTimers[userId] = setInterval(tick, 1000);
    }

    function updateTimerDisplay(userId) {
        // kept for compatibility — stage system handles display now
        const endTime = parseInt(localStorage.getItem(`processing_end_${userId}`));
        if (!endTime) return 0;
        return Math.max(0, endTime - Date.now());
    }

    function checkAndStartProcessingTimer() {
        if(!currentUser) return;
        const endTime = localStorage.getItem(`processing_end_${currentUser.id}`);
        if(endTime && parseInt(endTime) > Date.now()) {
            startProcessingTimer(currentUser.id);
        } else if(endTime && parseInt(endTime) <= Date.now()) {
            localStorage.removeItem(`processing_end_${currentUser.id}`);
            finalizeWithdrawalProcessing(currentUser.id);
        } else {
            // No active timer — check if we should show unverified or form
            const blocked = localStorage.getItem(`wd_blocked_${currentUser.id}`);
            if(blocked) {
                lastWithdrawalAmount = parseFloat(blocked) || 0;
                document.getElementById('blockedAmountDisplay').innerText = `$${lastWithdrawalAmount.toFixed(2)}`;
                setWithdrawalStage('unverified');
            } else {
                setWithdrawalStage('form');
            }
        }
    }
    async function finalizeWithdrawalProcessing(userId) {
        if(!currentUser || currentUser.id !== userId) return;

        const pending = withdrawalRequests.filter(r => r.userId === userId && r.status === 'pending')
            .sort((a,b) => new Date(b.date) - new Date(a.date))[0];

        // ── UNVERIFIED: block withdrawal, show red message ──
        if(!currentUser.isVerified) {
            lastWithdrawalAmount = pending ? pending.amount : 0;
            localStorage.setItem(`wd_blocked_${userId}`, lastWithdrawalAmount);
            if(pending) { pending.status = 'blocked'; if(!useBackend) saveLocalWithdrawals(); }
            document.getElementById('blockedAmountDisplay').innerText = `$${lastWithdrawalAmount.toFixed(2)}`;
            setWithdrawalStage('unverified');
            return;
        }

        // ── VERIFIED: process withdrawal normally ──
        localStorage.removeItem(`wd_blocked_${userId}`);
        if(pending) {
            pending.status = 'completed';
            if(!useBackend) saveLocalWithdrawals();
            if(currentUser.balance >= pending.amount) {
                currentUser.balance -= pending.amount;
                currentUser.totalWithdrawal += pending.amount;
                currentUser.transactions.unshift({ type: 'Withdrawal', amount: pending.amount, date: new Date().toISOString(), details: `${pending.method} - Completed` });
                if(!useBackend) saveLocalUsers();
                updateAllUI();
                document.getElementById('successAmountDisplay').innerText = `$${pending.amount.toFixed(2)}`;
                setWithdrawalStage('success');
                showToast(`✓ Withdrawal of $${pending.amount.toFixed(2)} completed!`);
            }
        } else {
            setWithdrawalStage('form');
        }
    }
